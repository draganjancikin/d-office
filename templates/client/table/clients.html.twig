<table class="table table-bordered table-hover dataTable" id="" width="100%" cellspacing="0">
    <thead class="thead-light"><tr><th>#</th><th>klijent</th><th>adresa</th></tr></thead>
    <tbody>
        {% for client in clients %}
        <tr>
            <td>{{ client.id }}</td>
            <td><a href="/clients/{{ client.id }}">{{ client.name }}</a></td>
            <td>
                {% set addressParts = [
                    (client.street ? client.street.name ~ ' ' : '') ~ (client.homeNumber|default(''))|trim,
                    client.city ? client.city.name : null,
                    client.country ? client.country.name : null
                ]|filter((v) => v) %}
                {{ addressParts|join(', ') }}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
